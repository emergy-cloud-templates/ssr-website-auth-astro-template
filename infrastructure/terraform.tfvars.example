aws_account_number = "123456789012"
project_id         = "example-project"

# Leave these empty to use CloudFront's default domain.
base_domain         = ""
aws_website_acm_arn = ""

# Runtime secrets (Supabase URL/keys, API keys, ...) are NOT tfvars.
# Put them in one AWS Secrets Manager JSON secret per environment, named
# "<env>/<project_id>" (e.g. "prod/example-project"). Required keys are
# listed in required-secret-keys.txt.
